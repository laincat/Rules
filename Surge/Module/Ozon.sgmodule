#!name =🐱 Ozon Rules
#!desc = 测试，Ozon 直连规则
#!author = Laincat
#!homepage = https://github.com/laincat/Rules
#!category = Laincat

[Rule]
RULE-SET, https://raw.githubusercontent.com/laincat/Rules/main/Surge/Ruleset/Ozon.list, nProxy, extended-matching, "update-interval=21600"

[Host]
*.ozon.ru = server:https://common.dot.dns.yandex.net/dns-query
*.ozone.ru = server:https://common.dot.dns.yandex.net/dns-query
*.ozonusercontent.com = server:https://common.dot.dns.yandex.net/dns-query
*.ozon-cdn.exponea.com = server:https://common.dot.dns.yandex.net/dns-query
*.seller.ozon.ru = server:https://common.dot.dns.yandex.net/dns-query
