[Script]
# > 18akmanhua Rules
会员 = type=http-response, pattern=https://18akmanhua.com/api/memberDetails, script-path=https://raw.githubusercontent.com/chmg2025/js/refs/heads/main/18ak.js, requires-body=true, timeout=60
视频 = type=http-response, pattern=^https:\/\/18akmanhua\.com\/api\/videoDetails\?id=\d+$, script-path=https://raw.githubusercontent.com/chmg2025/js/refs/heads/main/18ak.js, requires-body=true, timeout=60
播放 = type=http-response, pattern=https://18akmanhua.com/api/playNewVideos, script-path=https://raw.githubusercontent.com/chmg2025/js/refs/heads/main/18ak.js, requires-body=true, timeout=60
漫画 = type=http-response, pattern=^https:\/\/18akmanhua\.com\/api\/chaptersDetails\?chapter_id=\d+$, script-path=https://raw.githubusercontent.com/chmg2025/js/refs/heads/main/18ak.js, requires-body=true, timeout=60
漫画列表 = type=http-response, pattern=^https:\/\/18akmanhua\.com\/api\/chaptersDirectories\?.*$, script-path=https://raw.githubusercontent.com/chmg2025/js/refs/heads/main/18ak.js, requires-body=true, timeout=60
# > 麻豆视频 + 快手萝莉 Rules
会员 = type=http-response, pattern=https://((d2ht17eu5c0ykz|d1sn57bew5rukg).cloudfront.net|madddh5.yqsbdx.com)/api/app/user/info, script-path=https://raw.githubusercontent.com/chmg2025/js/refs/heads/main/mdsp.js, requires-body=true, timeout=60
视频 = type=http-response, pattern=https://((d2ht17eu5c0ykz|d1sn57bew5rukg).cloudfront.net|madddh5.yqsbdx.com)/api/app/media/play, script-path=https://raw.githubusercontent.com/chmg2025/js/refs/heads/main/mdsp.js, requires-body=true, timeout=60
广告 = type=http-response, pattern=https://((d2ht17eu5c0ykz|d1sn57bew5rukg).cloudfront.net|madddh5.yqsbdx.com)/(api/app/ping/config|api/app/media/v5/home), script-path=https://raw.githubusercontent.com/chmg2025/js/refs/heads/main/mdsp.js, requires-body=true, timeout=60
# > 糖心视频VIP+付费视频解锁 Rules
txxxxx = type=http-response, pattern=^https?:\/\/([a-z0-9-]+\.)*tx[a-z0-9-]*\.com\/h5\/(user\/info|system\/info|movie\/(detail|block|search)), script-path=https://raw.githubusercontent.com/Yu9191/Rewrite/refs/heads/main/txxxxx.js, requires-body=true, max-size=-1, timeout=60

[MITM]
hostname = %APPEND% 18akmanhua.com, d2ht17eu5c0ykz.cloudfront.net, d1sn57bew5rukg.cloudfront.net, *.yqsbdx.com, tx.*.com, tx.*.cn, txh057.com, txh*.com, txh066.com, tth.txh*.com, tth.txh069.com
